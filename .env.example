# ── Supabase Postgres (system of record) ────────────────────────────────────
# Prefer the IPv4 SESSION POOLER. The direct host (db.<ref>.supabase.co:5432) is
# served over IPv6 only and is unreachable on IPv4-only networks. Get the pooler
# string from: Supabase → Connect → Session pooler. Format:
#   postgresql://postgres.<ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Schema all emulator objects live in (never `public`).
DB_SCHEMA=emulator

# Base URL the dashboard uses to render copy-paste agent endpoints.
NEXT_PUBLIC_EMULATOR_BASE_URL=http://localhost:3002

# ── Auth / session ──────────────────────────────────────────────────────────
# HMAC secret for signing session + invite tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-hex-string

# ── Resend (transactional email for user onboarding) ────────────────────────
# API key from https://resend.com/api-keys and the verified From address.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="CE Admin <ce@autogrc.cloud>"

# ── Scheduler (serverless generators) ───────────────────────────────────────
# Secret guarding the cron tick endpoint (/api/cron/tick), which fires scheduled
# generators on serverless (Vercel), where the in-process 1s scheduler can't run.
# Set the same value in your cron trigger. Generate:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=replace-with-a-random-hex-string

# ── AutoX SSO (OIDC — Authorization Code + PKCE) ─────────────────────────────
# Register the client with an AutoX SSO admin (https://sso.autogrc.cloud/admin);
# they issue the id/secret and register your EXACT redirect + post-logout URIs.
#
# The two URL vars below are PER-ENVIRONMENT and must match a registered URI
# byte-for-byte; the other four (issuer/client_id/secret/resource) are the SAME
# in every environment.
#   dev  callback -> http://localhost:3002/api/auth/sso/callback
#   prod callback -> https://ce.autogrc.cloud/api/auth/sso/callback
#   dev  logout   -> http://localhost:3002/
#   prod logout   -> https://ce.autogrc.cloud/
# On Vercel, set these under Settings -> Environment Variables (scope: Production)
# with the prod values. Preview deploys get random per-commit hostnames that
# can't be pre-registered, so SSO does not work on Vercel previews.
AUTOX_ISSUER=https://sso.autogrc.cloud
AUTOX_CLIENT_ID=client-emulator
AUTOX_CLIENT_SECRET=replace-with-the-client-secret-from-registration
AUTOX_REDIRECT_URI=http://localhost:3002/api/auth/sso/callback
AUTOX_POST_LOGOUT_REDIRECT_URI=http://localhost:3002/
# Opt-in JWT access-token audience — required to receive the app-scoped
# autox:app_roles array that maps to administrator/consumer.
AUTOX_RESOURCE=https://sso.autogrc.cloud/api
